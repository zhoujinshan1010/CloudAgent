# 阿里云百炼 API Key (必需，用于 LLM 和 Embedding)
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY

# Redis 配置 (用于短期记忆，可选)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379
REDIS_TTL=1800

# Milvus 配置 (用于长期记忆，可选)
MILVUS_HOST=YOUR_MILVUS_HOST
MILVUS_PORT=19530
MILVUS_API_KEY=

# Neo4j 配置 (用于知识图谱，可选)
NEO4J_URI=bolt://YOUR_NEO4J_HOST:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# 日志级别
LOG_LEVEL=INFO

